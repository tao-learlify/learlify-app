# Ejemplo de variables de entorno para Docker
# Copiar este archivo a .env y configurar con tus valores

# API Configuration
VITE_API_URL=http://localhost:3100
VITE_WEBSOCKET=http://localhost:3100

# CDN/CloudFront
VITE_CLOUDFRONT=

# Language
VITE_FALLBACK_LANGUAGE=en

# Third-party services
VITE_STRIPE_PUBLIC_API_KEY=your_stripe_public_key
VITE_GOOGLE_CLIENT_ID=your_google_client_id
